@model CoffeeShopManager.Models.SanPham

@{
    ViewData["Title"] = "Chi tiết sản phẩm";

    var imagePath = "";

    if (string.IsNullOrWhiteSpace(Model.HinhAnh))
    {
        imagePath = "";
    }
    else if (Model.HinhAnh.StartsWith("/") || Model.HinhAnh.StartsWith("http"))
    {
        imagePath = Model.HinhAnh;
    }
    else
    {
        imagePath = Url.Content("~/images/" + Model.HinhAnh);
    }
}

<style>
    .admin-detail-page {
        min-height: 100vh;
        padding: 45px 60px;
        background-color: #f5efe5;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .admin-detail-card {
        max-width: 950px;
        margin: 0 auto;
        background: white;
        border: 2px solid #d1a856;
        border-radius: 22px;
        padding: 30px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 35px;
        box-shadow: 0 12px 25px rgba(0,0,0,0.18);
    }

    .admin-image-box {
        background-color: #fffaf0;
        border: 1px solid #e2c98d;
        border-radius: 18px;
        height: 340px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .admin-image-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .admin-info h2 {
        color: #2f241d;
        font-size: 32px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .info-line {
        margin-bottom: 12px;
        font-size: 17px;
        color: #3b2a20;
        font-weight: 700;
    }

    .price-box {
        display: inline-block;
        background: #ffd84d;
        color: #3b2a20;
        border: 2px solid #7b3f20;
        border-radius: 12px;
        padding: 10px 20px;
        font-size: 26px;
        font-weight: 900;
        margin: 15px 0;
    }

    .status-visible {
        color: green;
        font-weight: 900;
    }

    .status-hidden {
        color: red;
        font-weight: 900;
    }

    .admin-actions {
        margin-top: 25px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .admin-btn {
        border: none;
        border-radius: 10px;
        padding: 11px 20px;
        font-size: 15px;
        font-weight: 900;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        display: inline-block;
    }

    .edit-btn {
        background-color: #0d6efd;
        color: white;
    }

    .hide-btn {
        background-color: #6c757d;
        color: white;
    }

    .delete-btn {
        background-color: #dc3545;
        color: white;
    }

    .back-btn {
        background-color: #3b2a20;
        color: white;
    }

    .admin-btn:hover {
        opacity: 0.9;
        color: white;
    }

    @@media (max-width: 768px) {
        .admin-detail-card {
            grid-template-columns: 1fr;
        }

        .admin-detail-page {
            padding: 25px 18px;
        }
    }
</style>

<div class="admin-detail-page">
    <div class="admin-detail-card">
        <div class="admin-image-box">
            @if (!string.IsNullOrWhiteSpace(imagePath))
            {
                <img src="@imagePath" alt="@Model.TenSP" />
            }
            else
            {
                <span>Chưa có ảnh sản phẩm</span>
            }
        </div>

        <div class="admin-info">
            <h2>@Model.TenSP</h2>

            <div class="info-line">
                Mã sản phẩm: @Model.MaSP
            </div>

            <div class="info-line">
                Danh mục: @(Model.DanhMuc?.TenDanhMuc ?? "Chưa có danh mục")
            </div>

            <div class="price-box">
                @Model.Gia.ToString("N0") Đ
            </div>

            <div class="info-line">
                Trạng thái:
                @if (Model.IsAn)
                {
                    <span class="status-hidden">Đang ẩn</span>
                }
                else
                {
                    <span class="status-visible">Đang hiển thị</span>
                }
            </div>

            <div class="admin-actions">
                <a asp-controller="Admin"
                   asp-action="Edit"
                   asp-route-id="@Model.MaSP"
                   class="admin-btn edit-btn">
                    Sửa
                </a>

                <form asp-controller="Admin"
                      asp-action="AnHien"
                      asp-route-id="@Model.MaSP"
                      method="post">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="admin-btn hide-btn">
                        @(Model.IsAn ? "Hiện sản phẩm" : "Ẩn sản phẩm")
                    </button>
                </form>

                <a asp-controller="Admin"
                   asp-action="Delete"
                   asp-route-id="@Model.MaSP"
                   class="admin-btn delete-btn">
                    Xóa
                </a>

                <a asp-controller="Admin"
                   asp-action="Index"
                   class="admin-btn back-btn">
                    Quay lại
                </a>
            </div>
        </div>
    </div>
</div>