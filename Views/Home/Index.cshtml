@model IEnumerable<CoffeeShopManager.Models.SanPham>

@{
    ViewData["Title"] = "Thực Đơn";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');

    :root {
        --bonfire-bg: #EBE4D5;
        --bonfire-brown: #3C2A21;
        --cong-red: #8B2F29;
        --cong-text: #2C2C2C;
    }

    html {
        scroll-behavior: smooth;
    }

    /* KHỐI NỀN TỐI TRÀN TOÀN BỘ HAI BÊN MÀN HÌNH */
    .product-section-full {
        background-color: #3C2A21; /* Bạn có thể đổi thành mã màu nâu #3C2A21 tùy ý */
        background-image: url('https://www.transparenttextures.com/patterns/cream-paper.png');
        width: 100%;
        margin: 0;
        padding: 0;
    }

    .sidebar-link {
        color: var(--bonfire-bg);
        font-weight: 700;
        font-size: 1.1rem;
        text-transform: uppercase;
        text-decoration: none;
        display: block;
        padding: 8px 0;
        border-bottom: 1px dashed rgba(235, 228, 213, 0.3);
        transition: all 0.3s ease;
    }

        .sidebar-link:hover {
            color: #FFD93D;
            padding-left: 10px;
        }

    .category-section {
        scroll-margin-top: 150px;
    }

    .cong-title {
        font-family: 'Playfair Display', serif;
        color: var(--bonfire-brown);
        text-transform: uppercase;
        letter-spacing: 2px;
        border-bottom: 2px dashed var(--bonfire-brown);
        padding-bottom: 10px;
        margin-bottom: 20px;
        display: inline-block;
    }

    .cong-card {
        background: transparent;
        border: none;
        transition: transform 0.2s ease;
    }

        .cong-card:hover {
            transform: translateY(-5px);
        }

    .cong-img-wrapper {
        border: 3px solid var(--cong-bg);
        padding: 6px;
        background-color: #F4EFE6;
    }

    .cong-product-name {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 1.05rem;
        margin-top: 15px;
        color: var(--cong-bg);
    }

    .cong-product-price {
        font-weight: 700;
        font-size: 1.15rem;
        color: #FFD93D; /* Màu vàng nổi bật trên nền xanh tối */
    }

    .cong-btn {
        background-color: transparent;
        border: 2px solid var(--cong-bg);
        color: var(--cong-bg);
        font-weight: bold;
        text-transform: uppercase;
        border-radius: 0;
        padding: 5px 15px;
        transition: all 0.3s ease;
    }

        .cong-btn:hover {
            background-color: var(--cong-bg);
            color: var(--cong-green);
        }

    .cong-category-title {
        color: #FFD93D;
        border-left: 5px solid var(--cong-bg);
        padding-left: 12px;
        font-family: 'Playfair Display', serif;
        letter-spacing: 1px;
    }
</style>

<div class="container text-center py-2">
    <h2 class="cong-title">Thực Đơn Ghi Sổ</h2>
</div>

<div class="product-section-full">
    <div class="container py-5">
        <div class="row">

            <div class="col-lg-3 d-none d-lg-block">
                <div class="sticky-top" style="top: 150px; padding: 15px; border: 2px solid var(--cong-bg);">
                    <h4 class="font-weight-bold mb-4" style="font-family: 'Playfair Display', serif; color: #FFD93D;">MỤC LỤC</h4>
                    <ul class="list-unstyled">
                        @foreach (var group in Model.GroupBy(m => m.DanhMuc?.TenDanhMuc ?? "Món khác"))
                        {
                            var targetId = Uri.EscapeDataString(group.Key.Replace(" ", "-"));
                            <li class="mb-2">
                                <a href="#@targetId" class="sidebar-link">@group.Key</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="col-lg-9">
                @foreach (var group in Model.GroupBy(m => m.DanhMuc?.TenDanhMuc ?? "Món khác"))
                {
                    var targetId = Uri.EscapeDataString(group.Key.Replace(" ", "-"));

                    <div id="@targetId" class="category-section mb-5">
                        <h4 class="mb-4 text-uppercase fw-bold cong-category-title">
                            @group.Key
                        </h4>

                        <div class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-4 text-center px-2">
                            @foreach (var item in group)
                            {
                                <div class="col">
                                    <div class="cong-card d-flex flex-column h-100">

                                        <div class="cong-img-wrapper mx-auto" style="width: 100%; aspect-ratio: 1/1;">
                                            <img src="@(string.IsNullOrEmpty(item.HinhAnh) || item.HinhAnh == "Không" ? "https://congcaphe.com/uploads/dish/a9db9bb16c2763-87a387a6df1a07.png" : item.HinhAnh)"
                                                 alt="@item.TenSP" class="w-100 h-100" style="object-fit: cover;">
                                        </div>

                                        <div class="mt-auto pt-3">
                                            <h6 class="cong-product-name mb-1">@item.TenSP</h6>
                                            <p class="cong-product-price mb-3">@item.Gia.ToString("N0") Đ</p>
                                            <button class="btn cong-btn btn-sm w-100 mt-2">+ Ghi Sổ</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</div>